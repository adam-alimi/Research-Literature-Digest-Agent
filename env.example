# ── Research Literature Digest Agent ───────────────────────────
# Copy this file to .env and fill in your values.
# If running n8n via Docker, pass these as environment variables
# in your docker-compose.yml.  For n8n Cloud, add them under
# Settings → Environment Variables.

# Anthropic API key (starts with sk-ant-…)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Slack incoming webhook URL
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
